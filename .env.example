# ============================================
# Sovereign Chat Experience Starter - Client Configuration
# ============================================
# Copy this file to .env for local development
# For production deployment, see scripts/.azure-config

# ============================================
# Local Development
# ============================================

# Development proxy target (points to local server)
# Used by Vite dev server to proxy /api requests
VITE_PROXY_TARGET=http://localhost:3001

# Optional: Disable ESLint/TypeScript checker overlay
# Set to false to disable error overlay in browser during development
# VITE_DEV_CHECKER=false

# ============================================
# Production Build
# ============================================
# VITE_API_URL is set at BUILD TIME by ./scripts/deploy-to-azure.sh
# It reads from scripts/.azure-config and sets it during npm run build
# Do NOT set it here - it will be ignored in local dev (proxy is used instead)

# Example (set by deploy script):
# VITE_API_URL=https://foundry-chat-server.azurewebsites.net/api

# ============================================
# Server Configuration
# ============================================
# Streaming and datasource (mock/api) are controlled server-side
# The client fetches settings from GET /api/settings on load
# Use server admin endpoints to toggle at runtime:
#   curl -X POST http://localhost:3001/api/admin/streaming/toggle
#   curl -X POST http://localhost:3001/api/admin/datasource/toggle
