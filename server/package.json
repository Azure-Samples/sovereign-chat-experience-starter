{
  "name": "foundry-azure-local-chat-server",
  "version": "1.0.0",
  "description": "Backend server for Foundry Azure Local Chat with Microsoft Foundry",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "dev": "concurrently \"tsx watch index.ts\" \"npm run typecheck:watch\" \"npm run dev:lint-watch\"",
    "dev:lint-watch": "chokidar \"*.ts\" -c \"npm run lint\" --initial",
    "dev:no-lint": "tsx watch index.ts",
    "start": "tsx index.ts",
    "build": "echo 'No build step needed - tsx runs TypeScript directly'",
    "prebuild:check": "npm run lint && npm run typecheck",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "docker:build": "docker build -t foundry-chat-server .",
    "docker:run": "docker run -d --name foundry-chat -p 3001:3001 --env-file .env foundry-chat-server",
    "seed": "tsx scripts/seed-conversations.ts",
    "seed:batch": "tsx scripts/seed-conversations.ts batch",
    "seed:real": "tsx scripts/seed-conversations.ts real",
    "toggle": "./scripts/toggle.sh",
    "settings": "./scripts/show-settings.sh"
  },
  "dependencies": {
    "@azure/ai-projects": "^2.0.0-beta.4",
    "@azure/identity": "^4.13.1",
    "@azure/keyvault-secrets": "^4.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "esbuild": "^0.27.3",
    "express": "^4.21.0",
    "morgan": "^1.10.1",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.0.0",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.18.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.21.0"
  },
  "overrides": {
    "fast-xml-parser": ">=5.4.1 <6",
    "qs": ">=6.15.0 <7",
    "minimatch": ">=10.2.4",
    "ajv": ">=8.18.0",
    "@eslint/eslintrc": {
      "ajv": "^6.14.0"
    },
    "eslint": {
      "ajv": "^6.14.0"
    }
  }
}
