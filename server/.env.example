# ============================================
# Sovereign Chat Experience Starter - Server Configuration
# ============================================
#
# LOCAL DEVELOPMENT ONLY
# ----------------------
# Copy this file to .env for local development (npm run dev)
#
# PRODUCTION DEPLOYMENT:
# ----------------------
# - Azure App Service uses its own environment variables (NOT this .env)
# - Set during: ./scripts/setup-azure.sh (interactive prompts)
# - Or manually in: Azure Portal → App Service → Configuration
# - This .env file is NEVER deployed (explicitly excluded in deploy.sh)
#
# Deployment configuration: scripts/.azure-config
# Production env vars are set independently in Azure App Service

# ============================================
# Server Settings
# ============================================

# Server port (default: 3001)
SERVER_PORT=3001

# CORS allowed origins (comma-separated, REQUIRED)
# Server will not start without this
# Example: https://your-app.z6.web.core.windows.net,http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# ============================================
# AI Configuration (REQUIRED when DATASOURCES=api)
# ============================================

# AI Project endpoint
# Find in Microsoft Foundry: Project Settings > Properties > Endpoint
# Example: https://your-resource.services.ai.azure.com/api/projects/your-project
AI_PROJECT_ENDPOINT=

# Agent name with version
# Find in Microsoft Foundry: Agents > Your Agent > Name
# Format: agent-name:version
# Example: my-agent:1
AI_AGENT_ID=

# ============================================
# Admin Routes (Development/Testing)
# ============================================

# Enable admin routes in production
# In development (NODE_ENV !== "production"): Admin routes are ALWAYS enabled
# In production: Must explicitly set to "true" to enable admin endpoints
#
# Admin endpoints allow runtime configuration:
#   GET  /api/admin/config              - View current configuration
#   POST /api/admin/datasource/toggle   - Toggle between mock/api
#   POST /api/admin/streaming/toggle    - Toggle streaming on/off
#
# Security Note: Only enable in production if you need runtime configuration.
# For most deployments, configure via environment variables before deployment.
#
# Default: false (disabled in production for security)
# ENABLE_ADMIN_ROUTES=true

# ============================================
# Data Sources Configuration
# ============================================

# Data source mode (toggleable at runtime via /api/admin endpoints)
# Options: mock | api | byom
# - "mock" - In-memory mock storage only (no Azure required)
# - "api"  - Microsoft Foundry API (requires AI configuration above)
# - "byom" - BYOM: standard OpenAI Chat Completions API (/v1/chat/completions)
# Default: api
# Toggle at runtime: curl -X POST http://localhost:3001/api/admin/datasource/toggle
DATASOURCES=mock

# ============================================
# Streaming Configuration
# ============================================

# Enable streaming responses (toggleable at runtime via /api/admin endpoints)
# Options: enabled | disabled
# Default: enabled
# Toggle at runtime: curl -X POST http://localhost:3001/api/admin/streaming/toggle
STREAMING=enabled

# ============================================
# Production Deployment
# ============================================
# In Azure App Service, these values are automatically injected from Key Vault:
#   AI_PROJECT_ENDPOINT=@Microsoft.KeyVault(VaultName=...;SecretName=AI-PROJECT-ENDPOINT)
#   AI_AGENT_ID=@Microsoft.KeyVault(VaultName=...;SecretName=AI-AGENT-ID)
#
# The setup script (./scripts/setup-azure.sh) configures this automatically
# See scripts/.azure-config for deployment configuration

# ============================================
# Authentication (Entra ID)
# ============================================
# Uses DefaultAzureCredential which automatically handles:
# - Local dev: az login
# - Azure App Service: Managed Identity
# - Azure Container Apps: Managed Identity
# - GitHub Actions: Workload Identity
# No additional configuration needed!

# ============================================
# BYOM Configuration (REQUIRED when DATASOURCES=byom)
# ============================================
# Bring Your Own Model — uses the standard OpenAI Chat Completions API (/v1/chat/completions)
# The ChatCompletionsProvider connects to any endpoint implementing this format.

# Full URL to the chat completions endpoint
# Examples:
#   https://your-resource.openai.azure.com/openai/v1/chat/completions
#   https://api.openai.com/v1/chat/completions
#   http://localhost:8080/v1/chat/completions
# BYOM_ENDPOINT=

# Model name to send in requests
# Examples: gpt-4.1-mini, phi-4, mistral-7b
# BYOM_MODEL=

# Authentication mode
# Options: apikey | mtls
# - "apikey" - API key via header (default)
# - "mtls"   - Mutual TLS with client certificates (configured at deploy time)
# Default: apikey
# BYOM_AUTH_MODE=apikey

# API key (REQUIRED when BYOM_AUTH_MODE=apikey)
# Auto-detects Azure vs standard OpenAI and uses the correct header format
# BYOM_API_KEY=

# Client certificate paths (REQUIRED when BYOM_AUTH_MODE=mtls)
# These are typically mounted via K8s secrets or volume mounts at deploy time
# BYOM_CLIENT_CERT_PATH=
# BYOM_CLIENT_KEY_PATH=

# CA certificate for self-signed inference endpoints (optional, mTLS mode)
# BYOM_CA_CERT_PATH=

# System prompt prepended to all conversations (optional)
# BYOM_SYSTEM_PROMPT=
